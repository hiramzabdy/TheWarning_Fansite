---
import quotes from '../data/quotes.json';
---
<section id="quotes" class="relative border-t border-white/5 py-28">
  <div class="mesh-gradient"></div>
  <div class="relative z-10 mx-auto max-w-3xl px-6">
    <span class="section-label section-label-anim text-center block">In Their Words</span>
    <h2 class="section-label-anim mb-16 text-center font-serif text-3xl leading-tight sm:text-4xl md:text-5xl">
      What People <span class="text-crimson-500">Say</span>
    </h2>

    <div class="space-y-8">
      {quotes.map((q) => (
        <div class="quote-card-anim border-l-2 border-crimson-500 bg-white/[0.02] rounded-r-2xl p-6 sm:p-8">
          <blockquote class="text-lg italic leading-relaxed text-text-primary sm:text-xl">
            "{q.text}"
          </blockquote>
          <cite class="mt-4 block text-xs not-italic text-text-muted">
            — {q.cite}
          </cite>
        </div>
      ))}
    </div>
  </div>
</section>
